# 复制为项目根目录的 .env 后执行: docker compose up -d --build
#
# 重要：MYSQL_ROOT_PASSWORD 只能含 ASCII（英文、数字、常见英文标点）。
# PyMySQL 会用 latin-1 处理密码；填中文会报错：UnicodeEncodeError ... latin-1

MYSQL_ROOT_PASSWORD=MyBlog_2026!Root#Pass
MYSQL_DATABASE=MyBlog_2026!Database#Name

# JWT 密钥建议用一长串随机 ASCII
JWT_SECRET_KEY=change-me-to-a-long-random-ascii-string

# 前端 Nginx 映射到宿主的端口（默认 80）。若本机 80 被占用或无法绑定，改成例如 8080
HTTP_PORT=8080

# 后端映射到宿主端口（默认 8000），便于打开 http://127.0.0.1:8000/docs
# BACKEND_PORT=8000

# 可选：JWT 过期（分钟）
JWT_EXPIRE_MINUTES=60

# 浏览器直接访问后端时的跨域列表（逗号分隔）。仅用 Nginx 同源反代时可不改。
CORS_ORIGINS=http://localhost,http://127.0.0.1
