# =============================================================================
# 使用方法（本地或服务器都一样）
#   cp .env.docker.example .env
#   nano .env   # 修改下面「必须修改」的几项
#   docker compose up -d --build
#
# 服务器首次部署若 MySQL 卷已用旧密码初始化过，改密码需：
#   docker compose down -v   # 会清空 Docker 内数据库数据
#   docker compose up -d --build
# =============================================================================
#
# 重要：MYSQL_ROOT_PASSWORD 只能含 ASCII（英文、数字、常见英文标点）。
# PyMySQL 会用 latin-1 处理密码；填中文会报错。

# ----- 必须修改（不要使用示例里的默认值上线）-----
MYSQL_ROOT_PASSWORD=CHANGE_ME_ASCII_STRONG_PASSWORD
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_ASCII_STRING_AT_LEAST_32_CHARS

# ----- 可按需修改 -----
MYSQL_DATABASE=personal_blog

# 浏览器访问站点用的宿主端口（阿里云安全组需放行同一端口）
HTTP_PORT=80

# 后端 Swagger 等：默认映射宿主 8000；可不删此行
# BACKEND_PORT=8000

JWT_EXPIRE_MINUTES=60

# CORS：把你实际访问前端的地址都写上（公网 IP + 端口，逗号分隔无空格）
# 示例为当前服务器公网 IP；若改用 8080 访问，追加 http://123.56.23.170:8080
CORS_ORIGINS=http://123.56.23.170,http://localhost,http://127.0.0.1
